#!/usr/bin/env bun
/**
 * Take a screenshot of a local dev URL and upload to S3.
 *
 * Usage:
 *   bin/screenshot [options] <url> [filename]
 *   bin/screenshot /menu
 *   bin/screenshot --admin /admin/users
 *   bin/screenshot --device mobile /menu my-menu
 *
 * Options:
 *   --admin            Sign in as admin first (hits /dev/login_as_admin)
 *   --device <name>    Viewport: "mobile" (390x844), "desktop" (1280x900), or WxH
 *
 * Saves to tmp/screenshots/ locally.
 */

import { chromium } from "playwright";
import { mkdirSync, existsSync, statSync } from "fs";
import { parseArgs } from "util";

const { values, positionals } = parseArgs({
  args: Bun.argv.slice(2),
  options: {
    admin: { type: "boolean", default: false },
    device: { type: "string" },
  },
  allowPositionals: true,
  strict: true,
});

const url = positionals[0];
if (!url) {
  console.error("Usage: bin/screenshot [--admin] [--device mobile] <url> [filename]");
  process.exit(1);
}

const BASE_URL = "http://localhost:3000";
const fullUrl = url.startsWith("/") ? `${BASE_URL}${url}` : url;

// Auto-generate filename
let filename =
  positionals[1] ||
  url
    .replace(/^https?:\/\/[^/]*/, "")
    .replace(/^\//, "")
    .replace(/\//g, "-")
    .replace(/[^a-zA-Z0-9_.-]/g, "") ||
  "page";
filename = filename.replace(/\.png$/, "");
if (values.device) filename += `--${values.device}`;

// Resolve viewport
const PRESETS: Record<string, { width: number; height: number }> = {
  mobile: { width: 390, height: 844 },
  "iphone 14": { width: 390, height: 844 },
  "iphone se": { width: 375, height: 667 },
  tablet: { width: 768, height: 1024 },
  desktop: { width: 1280, height: 900 },
};

let viewport = { width: 1280, height: 900 };
if (values.device) {
  const preset = PRESETS[values.device.toLowerCase()];
  if (preset) {
    viewport = preset;
  } else if (values.device.includes(",")) {
    const [w, h] = values.device.split(",").map(Number);
    viewport = { width: w, height: h };
  }
}

const outputDir = "tmp/screenshots";
mkdirSync(outputDir, { recursive: true });
const outputPath = `${outputDir}/${filename}.png`;

const label = values.device ? ` (${values.device})` : "";
console.log(`  ${url}${label}...`);

const browser = await chromium.launch();
const context = await browser.newContext({ viewport });
const page = await context.newPage();

try {
  if (values.admin) {
    await page.goto(`${BASE_URL}/dev/login_as_admin`);
    await page.waitForLoadState("networkidle");
  }

  await page.goto(fullUrl);
  await page.waitForLoadState("networkidle");
  await page.screenshot({ fullPage: true, path: outputPath });
} finally {
  await browser.close();
}

if (!existsSync(outputPath) || statSync(outputPath).size === 0) {
  console.error(`Screenshot file is empty or missing: ${outputPath}`);
  process.exit(1);
}

const sizeKb = Math.round(statSync(outputPath).size / 1024);
console.log(`  Saved to ${outputPath} (${sizeKb}K)`);
