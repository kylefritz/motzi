#!/usr/bin/env bash
#
# Take screenshots of multiple URLs and append them to the current PR description.
#
# Usage:
#   bin/screenshot-pr [--device "iPhone 14"] <url> [url2] [url3] ...
#   bin/screenshot-pr /404 /422 /500.html
#   bin/screenshot-pr /menu /admin/error_feedbacks
#   bin/screenshot-pr --device "iPhone 14" /rails/mailers/reminder_mailer/havent_ordered_email
#
# Each URL is screenshotted and uploaded to S3 under the PR's folder.
# New screenshots are appended to any existing ## Screenshots section.
# Use --replace to clear existing screenshots first.
#
# Options:
#   --device <name>    Emulate a device (e.g. "iPhone 14", "Pixel 7")
#   --replace          Replace existing screenshots instead of appending
#
# Requirements: gh cli, npx playwright, aws cli

set -euo pipefail

DEVICE=""
REPLACE=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    --device)
      DEVICE="$2"
      shift 2
      ;;
    --replace)
      REPLACE=true
      shift
      ;;
    *)
      break
      ;;
  esac
done

if [[ $# -eq 0 ]]; then
  echo "Usage: bin/screenshot-pr [--device \"iPhone 14\"] [--replace] <url> [url2] [url3] ..."
  exit 1
fi

# Get PR number
PR_NUMBER=$(gh pr view --json number --jq .number 2>/dev/null || echo "")
if [[ -z "$PR_NUMBER" ]]; then
  echo "❌ No PR found for current branch. Push and create a PR first."
  exit 1
fi

echo "📋 PR #${PR_NUMBER}"
echo ""

MARKDOWN=""
FAILURES=0

for URL in "$@"; do
  # Resolve relative paths
  if [[ "$URL" == /* ]]; then
    FULL_URL="http://localhost:3000${URL}"
  else
    FULL_URL="$URL"
  fi

  # Generate filename from path
  FILENAME=$(echo "$URL" | sed 's|^https\?://[^/]*||' | sed 's|^/||' | sed 's|/|-|g' | sed 's|[^a-zA-Z0-9_.-]||g')
  [[ -z "$FILENAME" ]] && FILENAME="page"
  FILENAME="${FILENAME%.png}"
  if [[ -n "$DEVICE" ]]; then
    DEVICE_SLUG=$(echo "$DEVICE" | tr '[:upper:] ' '[:lower:]-')
    FILENAME="${FILENAME}--${DEVICE_SLUG}"
  fi

  # Take screenshot
  LOCAL_DIR="$HOME/Desktop/screenshots"
  mkdir -p "$LOCAL_DIR"
  LOCAL_PATH="${LOCAL_DIR}/${FILENAME}.png"
  echo "📸 ${URL}${DEVICE:+ (${DEVICE})}..."
  SCREENSHOT_CMD=(npx --yes playwright screenshot --full-page -b chromium)
  if [[ -n "$DEVICE" ]]; then
    # Use viewport-size instead of --device to avoid WebKit dependency.
    # Map known devices to their viewport sizes.
    case "$DEVICE" in
      "iPhone 14"|"iPhone 13"|"iPhone 12") SCREENSHOT_CMD+=(--viewport-size "390,844") ;;
      "iPhone 14 Pro Max")                 SCREENSHOT_CMD+=(--viewport-size "430,932") ;;
      "iPhone SE")                         SCREENSHOT_CMD+=(--viewport-size "375,667") ;;
      "Pixel 7")                           SCREENSHOT_CMD+=(--viewport-size "412,915") ;;
      *)                                   SCREENSHOT_CMD+=(--device "$DEVICE") ;;
    esac
  fi
  SCREENSHOT_CMD+=("${FULL_URL}" "${LOCAL_PATH}")
  if ! "${SCREENSHOT_CMD[@]}"; then
    echo "   ❌ Screenshot failed"
    FAILURES=$((FAILURES + 1))
    continue
  fi

  if [[ ! -s "$LOCAL_PATH" ]]; then
    echo "   ❌ Screenshot file is empty or missing"
    FAILURES=$((FAILURES + 1))
    continue
  fi

  # Upload to S3
  S3_KEY="public/gh/pr-${PR_NUMBER}/${FILENAME}.png"
  S3_URL="https://motzi.s3.us-east-1.amazonaws.com/${S3_KEY}"
  if ! aws s3 cp "${LOCAL_PATH}" "s3://motzi/${S3_KEY}"; then
    echo "   ❌ S3 upload failed"
    FAILURES=$((FAILURES + 1))
    continue
  fi

  # Verify the upload is publicly accessible
  HTTP_STATUS=$(curl -s -o /dev/null -w "%{http_code}" "$S3_URL")
  if [[ "$HTTP_STATUS" != "200" ]]; then
    echo "   ❌ Upload succeeded but URL returned HTTP ${HTTP_STATUS}"
    FAILURES=$((FAILURES + 1))
    continue
  fi

  echo "   ✓ ${S3_URL}"

  # Build markdown
  DISPLAY_NAME=$(echo "$URL" | sed 's|^/||')
  MARKDOWN="${MARKDOWN}
### ${DISPLAY_NAME}
![${DISPLAY_NAME}](${S3_URL})
"
done

if [[ -z "$MARKDOWN" ]]; then
  echo ""
  echo "❌ All screenshots failed. PR not updated."
  exit 1
fi

# Get current PR body and update screenshots
CURRENT_BODY=$(gh pr view --json body --jq .body)

HAS_SCREENSHOTS=$(echo "$CURRENT_BODY" | grep -c '^## Screenshots$' || true)

if [[ "$REPLACE" == "true" ]] || [[ "$HAS_SCREENSHOTS" -eq 0 ]]; then
  # Remove existing section (if any) and start fresh
  if [[ "$HAS_SCREENSHOTS" -gt 0 ]] && [[ "$REPLACE" == "true" ]]; then
    echo "⚠️  Replacing existing screenshots section"
  fi
  CLEAN_BODY=$(echo "$CURRENT_BODY" | sed '/^## Screenshots$/,$d')
  NEW_BODY="${CLEAN_BODY}
## Screenshots
${MARKDOWN}"
else
  # Append to existing screenshots section
  echo "📎 Appending to existing screenshots section"
  NEW_BODY="${CURRENT_BODY}
${MARKDOWN}"
fi

# Update PR
gh pr edit "$PR_NUMBER" --body "$NEW_BODY"

echo ""
if [[ $FAILURES -gt 0 ]]; then
  echo "⚠️  PR #${PR_NUMBER} updated but ${FAILURES} screenshot(s) failed"
  exit 1
else
  echo "✅ PR #${PR_NUMBER} updated with $# screenshot(s)"
fi
