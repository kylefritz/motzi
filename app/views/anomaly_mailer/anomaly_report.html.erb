<h2>Activity Report: <%= @analysis.week_id %></h2>

<div style="white-space: pre-wrap; font-family: monospace; font-size: 14px; line-height: 1.5; background: #f9f9f9; padding: 16px; border-radius: 4px;">
<%= simple_format(@analysis.result) %>
</div>

<hr style="margin-top: 24px; border: none; border-top: 1px solid #ccc;">
<p style="color: #999; font-size: 12px;">
  Generated at <%= @analysis.created_at.strftime("%Y-%m-%d %l:%M%P %Z") %>
  using <%= @analysis.model_used %>
  (<%= @analysis.input_tokens %> input / <%= @analysis.output_tokens %> output tokens)
</p>
